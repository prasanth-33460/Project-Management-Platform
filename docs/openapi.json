{
  "openapi": "3.0.3",
  "info": {
    "title": "Project Management Platform API",
    "description": "Jira-like backend: projects, issues, sprints, workflows, comments, notifications, and real-time WebSocket updates.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "http://localhost:8080/api", "description": "Local development" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "details": {}
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id":           { "type": "string", "format": "uuid" },
          "email":        { "type": "string" },
          "display_name": { "type": "string" },
          "handle":       { "type": "string", "description": "@mention handle" },
          "avatar_url":   { "type": "string", "nullable": true }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "user":  { "$ref": "#/components/schemas/User" }
        }
      },
      "Project": {
        "type": "object",
        "properties": {
          "id":          { "type": "string", "format": "uuid" },
          "key":         { "type": "string", "example": "PROJ" },
          "name":        { "type": "string" },
          "description": { "type": "string" },
          "created_at":  { "type": "string", "format": "date-time" },
          "updated_at":  { "type": "string", "format": "date-time" }
        }
      },
      "WorkflowStatus": {
        "type": "object",
        "properties": {
          "id":         { "type": "string", "format": "uuid" },
          "name":       { "type": "string" },
          "color":      { "type": "string", "example": "#6B7280" },
          "position":   { "type": "integer" },
          "is_default": { "type": "boolean" },
          "is_done":    { "type": "boolean" }
        }
      },
      "Issue": {
        "type": "object",
        "properties": {
          "id":           { "type": "string", "format": "uuid" },
          "project_id":   { "type": "string", "format": "uuid" },
          "issue_key":    { "type": "string", "example": "PROJ-42" },
          "type":         { "type": "string", "enum": ["epic","story","task","bug","subtask"] },
          "title":        { "type": "string" },
          "description":  { "type": "string" },
          "status":       { "$ref": "#/components/schemas/WorkflowStatus" },
          "priority":     { "type": "string", "enum": ["low","medium","high","critical"] },
          "assignee":     { "$ref": "#/components/schemas/User" },
          "reporter":     { "$ref": "#/components/schemas/User" },
          "story_points": { "type": "integer", "nullable": true },
          "labels":       { "type": "array", "items": { "type": "string" } },
          "sprint_id":    { "type": "string", "format": "uuid", "nullable": true },
          "parent_id":    { "type": "string", "format": "uuid", "nullable": true },
          "version":      { "type": "integer" },
          "created_at":   { "type": "string", "format": "date-time" },
          "updated_at":   { "type": "string", "format": "date-time" }
        }
      },
      "Sprint": {
        "type": "object",
        "properties": {
          "id":         { "type": "string", "format": "uuid" },
          "project_id": { "type": "string", "format": "uuid" },
          "name":       { "type": "string" },
          "goal":       { "type": "string" },
          "start_date": { "type": "string", "format": "date" },
          "end_date":   { "type": "string", "format": "date" },
          "status":     { "type": "string", "enum": ["planned","active","completed"] },
          "velocity":   { "type": "integer", "nullable": true }
        }
      },
      "Comment": {
        "type": "object",
        "properties": {
          "id":         { "type": "string", "format": "uuid" },
          "issue_id":   { "type": "string", "format": "uuid" },
          "author":     { "$ref": "#/components/schemas/User" },
          "body":       { "type": "string" },
          "parent_id":  { "type": "string", "format": "uuid", "nullable": true },
          "replies":    { "type": "array", "items": { "$ref": "#/components/schemas/Comment" } },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "Notification": {
        "type": "object",
        "properties": {
          "id":         { "type": "string", "format": "uuid" },
          "type":       { "type": "string", "enum": ["assigned","mentioned","status_changed","comment_added","sprint_updated"] },
          "title":      { "type": "string" },
          "body":       { "type": "string", "nullable": true },
          "read":       { "type": "boolean" },
          "ref_id":     { "type": "string", "format": "uuid", "nullable": true },
          "ref_type":   { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "CustomFieldDefinition": {
        "type": "object",
        "properties": {
          "id":         { "type": "string", "format": "uuid" },
          "name":       { "type": "string" },
          "field_type": { "type": "string", "enum": ["text","number","dropdown","date"] },
          "options":    { "type": "array", "items": { "type": "string" } },
          "required":   { "type": "boolean" }
        }
      },
      "CustomFieldValue": {
        "type": "object",
        "properties": {
          "field_id":   { "type": "string", "format": "uuid" },
          "field_name": { "type": "string" },
          "field_type": { "type": "string" },
          "value":      { "type": "string", "nullable": true }
        }
      },
      "PagedIssues": {
        "type": "object",
        "properties": {
          "items":       { "type": "array", "items": { "$ref": "#/components/schemas/Issue" } },
          "total":       { "type": "integer" },
          "next_cursor": { "type": "string" }
        }
      }
    }
  },
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new user",
        "security": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "required": ["email","display_name","password"],
            "properties": {
              "email":        { "type": "string", "format": "email" },
              "display_name": { "type": "string" },
              "password":     { "type": "string", "minLength": 8 }
            }
          }}}
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "409": { "description": "Email already registered" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login and get JWT",
        "security": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "required": ["email","password"],
            "properties": {
              "email":    { "type": "string" },
              "password": { "type": "string" }
            }
          }}}
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/projects": {
      "get": {
        "tags": ["Projects"],
        "summary": "List projects for the current user",
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Project" } } } } } }
      },
      "post": {
        "tags": ["Projects"],
        "summary": "Create a project",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "required": ["key","name"],
            "properties": {
              "key":         { "type": "string", "example": "PROJ" },
              "name":        { "type": "string" },
              "description": { "type": "string" }
            }
          }}}
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } } },
          "409": { "description": "Project key already in use" }
        }
      }
    },
    "/projects/{id}": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "get":    { "tags": ["Projects"], "summary": "Get project by ID", "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Project" } } } } } },
      "patch":  { "tags": ["Projects"], "summary": "Update project", "requestBody": { "content": { "application/json": { "schema": { "type": "object", "properties": { "name": { "type": "string" }, "description": { "type": "string" } } } } } }, "responses": { "200": { "description": "OK" } } },
      "delete": { "tags": ["Projects"], "summary": "Delete project", "responses": { "204": { "description": "Deleted" } } }
    },
    "/projects/{id}/board": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "get": { "tags": ["Projects"], "summary": "Get board state (project + issues grouped by status)", "responses": { "200": { "description": "OK" } } }
    },
    "/projects/{id}/backlog": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "get": { "tags": ["Projects"], "summary": "List backlog issues (no sprint)", "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Issue" } } } } } } }
    },
    "/projects/{id}/activity": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "get": {
        "tags": ["Projects"],
        "summary": "Paginated activity feed for a project",
        "parameters": [
          { "name": "cursor", "in": "query", "schema": { "type": "string" } },
          { "name": "limit",  "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/projects/{id}/issues": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "post": {
        "tags": ["Issues"],
        "summary": "Create an issue in a project",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": {
            "type": "object",
            "required": ["type","title"],
            "properties": {
              "type":        { "type": "string", "enum": ["epic","story","task","bug","subtask"] },
              "title":       { "type": "string" },
              "description": { "type": "string" },
              "priority":    { "type": "string", "enum": ["low","medium","high","critical"] },
              "assignee_id": { "type": "string", "format": "uuid" },
              "sprint_id":   { "type": "string", "format": "uuid" },
              "parent_id":   { "type": "string", "format": "uuid" },
              "story_points":{ "type": "integer" },
              "labels":      { "type": "array", "items": { "type": "string" } }
            }
          }}}
        },
        "responses": { "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Issue" } } } } }
      }
    },
    "/projects/{id}/workflow/statuses": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "get":  { "tags": ["Workflow"], "summary": "List workflow statuses for a project", "responses": { "200": { "description": "OK" } } },
      "post": {
        "tags": ["Workflow"],
        "summary": "Create a workflow status",
        "requestBody": { "required": true, "content": { "application/json": { "schema": {
          "type": "object", "required": ["name"],
          "properties": {
            "name":       { "type": "string" },
            "color":      { "type": "string", "example": "#3B82F6" },
            "position":   { "type": "integer" },
            "is_default": { "type": "boolean" },
            "is_done":    { "type": "boolean" }
          }
        }}}},
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/projects/{id}/workflow/transitions": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "post": {
        "tags": ["Workflow"],
        "summary": "Define an allowed status transition (optionally with auto-actions and validation rules)",
        "requestBody": { "required": true, "content": { "application/json": { "schema": {
          "type": "object", "required": ["from_status_id","to_status_id"],
          "properties": {
            "from_status_id":   { "type": "string", "format": "uuid" },
            "to_status_id":     { "type": "string", "format": "uuid" },
            "auto_actions":     { "type": "array", "items": { "type": "object", "properties": { "type": { "type": "string" }, "field": { "type": "string" }, "value": { "type": "string" } } } },
            "validation_rules": { "type": "array", "items": { "type": "object", "properties": { "field": { "type": "string" }, "operator": { "type": "string", "enum": ["not_empty","is_empty"] }, "message": { "type": "string" } } } }
          }
        }}}},
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/projects/{id}/workflow/transitions/{transitionId}": {
      "parameters": [
        { "name": "id",           "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
        { "name": "transitionId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
      ],
      "delete": { "tags": ["Workflow"], "summary": "Delete a transition rule", "responses": { "204": { "description": "Deleted" } } }
    },
    "/projects/{id}/custom-fields": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "get":  { "tags": ["Custom Fields"], "summary": "List custom field definitions for a project", "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CustomFieldDefinition" } } } } } } },
      "post": {
        "tags": ["Custom Fields"],
        "summary": "Create a custom field definition",
        "requestBody": { "required": true, "content": { "application/json": { "schema": {
          "type": "object", "required": ["name","field_type"],
          "properties": {
            "name":       { "type": "string" },
            "field_type": { "type": "string", "enum": ["text","number","dropdown","date"] },
            "options":    { "type": "array", "items": { "type": "string" } },
            "required":   { "type": "boolean" }
          }
        }}}},
        "responses": { "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CustomFieldDefinition" } } } } }
      }
    },
    "/projects/{id}/custom-fields/{fieldId}": {
      "parameters": [
        { "name": "id",      "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
        { "name": "fieldId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
      ],
      "delete": { "tags": ["Custom Fields"], "summary": "Delete a custom field definition", "responses": { "204": { "description": "Deleted" } } }
    },
    "/projects/{id}/sprints": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "get":  { "tags": ["Sprints"], "summary": "List sprints for a project", "responses": { "200": { "description": "OK" } } },
      "post": {
        "tags": ["Sprints"],
        "summary": "Create a sprint",
        "requestBody": { "required": true, "content": { "application/json": { "schema": {
          "type": "object", "required": ["name"],
          "properties": {
            "name":       { "type": "string" },
            "goal":       { "type": "string" },
            "start_date": { "type": "string", "example": "2026-04-15" },
            "end_date":   { "type": "string", "example": "2026-04-29" }
          }
        }}}},
        "responses": { "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Sprint" } } } } }
      }
    },
    "/issues/{id}": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "get":    { "tags": ["Issues"], "summary": "Get issue by ID", "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Issue" } } } } } },
      "patch":  {
        "tags": ["Issues"], "summary": "Update issue fields (not status — use /transitions for that)",
        "requestBody": { "content": { "application/json": { "schema": {
          "type": "object",
          "properties": {
            "title":        { "type": "string" },
            "description":  { "type": "string" },
            "priority":     { "type": "string" },
            "assignee_id":  { "type": "string", "format": "uuid" },
            "story_points": { "type": "integer" },
            "labels":       { "type": "array", "items": { "type": "string" } }
          }
        }}}},
        "responses": { "200": { "description": "OK" } }
      },
      "delete": { "tags": ["Issues"], "summary": "Delete issue", "responses": { "204": { "description": "Deleted" } } }
    },
    "/issues/{id}/transitions": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "post": {
        "tags": ["Issues"],
        "summary": "Transition issue to a new status",
        "description": "Returns 422 with allowed_transitions if the target isn't reachable. Returns 409 on optimistic lock conflict. Returns 422 with validation rule details if a rule blocks the transition.",
        "requestBody": { "required": true, "content": { "application/json": { "schema": {
          "type": "object", "required": ["target_status_id"],
          "properties": { "target_status_id": { "type": "string", "format": "uuid" } }
        }}}},
        "responses": {
          "200": { "description": "OK — issue with updated status" },
          "409": { "description": "Optimistic lock conflict — re-fetch and retry" },
          "422": { "description": "Transition not allowed or validation rule failed" }
        }
      }
    },
    "/issues/{id}/watch": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "post":   { "tags": ["Issues"], "summary": "Watch an issue", "responses": { "200": { "description": "OK" } } },
      "delete": { "tags": ["Issues"], "summary": "Unwatch an issue", "responses": { "200": { "description": "OK" } } }
    },
    "/issues/{id}/comments": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "get":  { "tags": ["Comments"], "summary": "List comments on an issue (threaded)", "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Comment" } } } } } } },
      "post": {
        "tags": ["Comments"],
        "summary": "Add a comment — supports @handle mentions and thread replies via parent_id",
        "requestBody": { "required": true, "content": { "application/json": { "schema": {
          "type": "object", "required": ["body"],
          "properties": {
            "body":      { "type": "string" },
            "parent_id": { "type": "string", "format": "uuid", "description": "Set to create a threaded reply" }
          }
        }}}},
        "responses": { "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Comment" } } } } }
      }
    },
    "/issues/{id}/custom-fields": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "get": { "tags": ["Custom Fields"], "summary": "Get custom field values for an issue", "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CustomFieldValue" } } } } } } },
      "put": {
        "tags": ["Custom Fields"],
        "summary": "Set custom field values on an issue (upsert array)",
        "requestBody": { "required": true, "content": { "application/json": { "schema": {
          "type": "array",
          "items": {
            "type": "object", "required": ["field_id"],
            "properties": {
              "field_id": { "type": "string", "format": "uuid" },
              "value":    { "type": "string", "nullable": true }
            }
          }
        }}}},
        "responses": { "200": { "description": "OK — all current values for the issue" } }
      }
    },
    "/comments/{id}": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "patch":  { "tags": ["Comments"], "summary": "Update a comment (author only)", "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "body": { "type": "string" } } } } } }, "responses": { "200": { "description": "OK" } } },
      "delete": { "tags": ["Comments"], "summary": "Delete a comment (author only)", "responses": { "204": { "description": "Deleted" } } }
    },
    "/sprints/{id}": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "get":    { "tags": ["Sprints"], "summary": "Get sprint by ID", "responses": { "200": { "description": "OK" } } },
      "patch":  { "tags": ["Sprints"], "summary": "Update sprint", "responses": { "200": { "description": "OK" } } },
      "delete": { "tags": ["Sprints"], "summary": "Delete sprint", "responses": { "204": { "description": "Deleted" } } }
    },
    "/sprints/{id}/start": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "post": { "tags": ["Sprints"], "summary": "Start a sprint (only one active sprint per project)", "responses": { "200": { "description": "OK" } } }
    },
    "/sprints/{id}/complete": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "post": {
        "tags": ["Sprints"],
        "summary": "Complete a sprint — calculates velocity, returns incomplete issues",
        "requestBody": { "content": { "application/json": { "schema": {
          "type": "object",
          "properties": {
            "carry_over_issue_ids": { "type": "array", "items": { "type": "string", "format": "uuid" } },
            "next_sprint_id":       { "type": "string", "format": "uuid", "nullable": true }
          }
        }}}},
        "responses": { "200": { "description": "OK — sprint result with velocity and incomplete issues" } }
      }
    },
    "/sprints/{id}/move-issue": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "post": {
        "tags": ["Sprints"],
        "summary": "Move an issue into this sprint",
        "requestBody": { "required": true, "content": { "application/json": { "schema": {
          "type": "object", "required": ["issue_id"],
          "properties": { "issue_id": { "type": "string", "format": "uuid" } }
        }}}},
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/sprints/move-to-backlog": {
      "post": {
        "tags": ["Sprints"],
        "summary": "Move an issue to the backlog",
        "requestBody": { "required": true, "content": { "application/json": { "schema": {
          "type": "object", "required": ["issue_id"],
          "properties": { "issue_id": { "type": "string", "format": "uuid" } }
        }}}},
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/search": {
      "get": {
        "tags": ["Search"],
        "summary": "Full-text search across issue titles, descriptions, and comment bodies",
        "parameters": [
          { "name": "q",           "in": "query", "schema": { "type": "string" } },
          { "name": "project_id",  "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "status_id",   "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "assignee_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "priority",    "in": "query", "schema": { "type": "string", "enum": ["low","medium","high","critical"] } },
          { "name": "type",        "in": "query", "schema": { "type": "string", "enum": ["epic","story","task","bug","subtask"] } },
          { "name": "cursor",      "in": "query", "schema": { "type": "string" } },
          { "name": "limit",       "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PagedIssues" } } } } }
      }
    },
    "/notifications": {
      "get": {
        "tags": ["Notifications"],
        "summary": "List notifications for the current user",
        "parameters": [
          { "name": "cursor", "in": "query", "schema": { "type": "string" } },
          { "name": "limit",  "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/notifications/read-all": {
      "post": { "tags": ["Notifications"], "summary": "Mark all notifications as read", "responses": { "200": { "description": "OK" } } }
    },
    "/notifications/{id}/read": {
      "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
      "post": { "tags": ["Notifications"], "summary": "Mark a single notification as read", "responses": { "200": { "description": "OK" } } }
    },
    "/ws": {
      "get": {
        "tags": ["WebSocket"],
        "summary": "WebSocket endpoint for real-time board updates",
        "description": "Upgrade to WebSocket. Connect to a project room and optionally an issue room. Pass `since=<unix_ms>` to replay missed events on reconnect.\n\n**Event types:** `issue_created`, `issue_updated`, `issue_moved`, `issue_deleted`, `comment_added`, `sprint_updated`, `presence_update`\n\n**Heartbeat:** Send `{\"type\":\"heartbeat\"}` every 30s to keep the connection alive.",
        "parameters": [
          { "name": "user_id",    "in": "query", "required": true,  "schema": { "type": "string", "format": "uuid" } },
          { "name": "project_id", "in": "query", "required": false, "schema": { "type": "string", "format": "uuid" } },
          { "name": "issue_id",   "in": "query", "required": false, "schema": { "type": "string", "format": "uuid" } },
          { "name": "since",      "in": "query", "required": false, "schema": { "type": "integer" }, "description": "Unix millisecond timestamp — replays events after this point on connect" }
        ],
        "responses": { "101": { "description": "Switching Protocols" } }
      }
    }
  }
}
